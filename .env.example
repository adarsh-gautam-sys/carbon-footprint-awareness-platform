# Copy to .env for local development. Do not commit real secrets.

GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1
CLOUD_RUN_SERVICE=promptwars-agent

# Application secrets should be stored in Secret Manager for Cloud Run.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Set true in Cloud Run when Firestore is configured.
FIRESTORE_ENABLED=false
LOCAL_DATA_DIR=/tmp/carbon-footprint-platform
